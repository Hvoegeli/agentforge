# AgentForge environment configuration — copy to .env and fill in
# Never commit a real .env (it's gitignored)

# === LLM access ============================================================
# OpenRouter is the primary provider — one API key, OpenAI-compatible endpoint,
# fallback chains across all the open-weight models we use.
# Get a key at https://openrouter.ai/keys (set a hard spend cap, e.g. $5/day)
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Together AI is the secondary provider (direct access to workhorse open-weights)
# Optional for MVP; uncomment if you want failover beyond OpenRouter's own
# TOGETHER_API_KEY=

# === Model backend =========================================================
# 'ollama'     -> local dev: free, fast iteration. Runs a small model (Mistral-7B
#                 or a small WhiteRabbitNeo) on your machine via Ollama. $0 API cost.
# 'openrouter' -> CI / scheduled runs / the demo: WhiteRabbitNeo-70B etc., costs credits.
# The Judge ALWAYS uses OpenRouter (it must be a different model family from the Red
# Team, and the small local models aren't reliable enough as a judge).
MODEL_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_RED_TEAM_MODEL=mistral:7b-instruct
# OpenRouter model ids used when MODEL_BACKEND=openrouter:
OPENROUTER_RED_TEAM_MODEL=cognitivecomputations/whiterabbitneo-70b
OPENROUTER_RED_TEAM_FALLBACK=cognitivecomputations/dolphin-3.0-llama3.1-70b
OPENROUTER_MUTATION_MODEL=qwen/qwen3-32b
OPENROUTER_JUDGE_MODEL=mistralai/mistral-large-2411
OPENROUTER_DOCS_MODEL=meta-llama/llama-3.1-8b-instruct

# === Target Co-Pilot =======================================================
# The deployed Co-Pilot we attack. AgentForge reaches it over HTTP exactly
# as an external user would.
COPILOT_BASE_URL=https://copilot.example.com
# Credentials AgentForge uses to authenticate against the Co-Pilot's session model.
# Use a dedicated test account; do NOT reuse a real clinician account.
COPILOT_USERNAME=agentforge_test
COPILOT_PASSWORD=REPLACE_ME
# Pinned target SHA for the regression baseline (set during MVP-Tue build-out)
COPILOT_TARGET_SHA=

# === Dashboard =============================================================
# HTTP basic auth for the read-mostly observability dashboard
DASHBOARD_BASIC_AUTH_USER=demo
DASHBOARD_BASIC_AUTH_PASS=REPLACE_ME

# === Storage ===============================================================
# Where the findings DB + JSONL trace log live
SQLITE_DB_PATH=data/agentforge.sqlite
TRACE_LOG_PATH=logs/agentforge-trace.jsonl

# === Rate limits + budget guards ===========================================
# Attacks per minute against the target (Co-Pilot has ~3.7 GB RAM — be gentle)
RATE_LIMIT_RPM=20
# Cost-without-signal kill switch ($-spent per category before Orchestrator halts)
COST_NO_SIGNAL_CEILING_USD=0.50
# Hard per-run timeout (seconds)
RUN_TIMEOUT_SINGLE_TURN=120
RUN_TIMEOUT_MULTI_TURN=300

# === Judge confidence thresholds ===========================================
# Deterministic invariant checks are yes/no — no confidence value applies.
# These thresholds govern the LLM-Judge's semantic-judgement verdicts only:
#   confidence >= JUDGE_AUTOFILE_CONFIDENCE -> auto-file the vuln report
#       (HIGH-and-below auto-file as final; CRITICAL is ALWAYS held as a draft
#        for human review regardless of confidence — the trust gate)
#   JUDGE_LEAD_FLOOR <= confidence < JUDGE_AUTOFILE -> human-review queue
#   confidence < JUDGE_LEAD_FLOOR -> stored as a 'lead', not a confirmed finding
JUDGE_AUTOFILE_CONFIDENCE=0.85
JUDGE_LEAD_FLOOR_CONFIDENCE=0.50

# === Logging ===============================================================
LOG_LEVEL=INFO
